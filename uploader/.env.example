# Copy this to .env and fill in your values

# Google Sheet ID (from the URL)
SPREADSHEET_ID=your_spreadsheet_id_here

# Service account for Sheets read/write
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

# YouTube OAuth2 credentials (downloaded from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS=./credentials/youtube_client_secrets.json

# Cached YouTube token (auto-created after first login)
YOUTUBE_TOKEN_FILE=./credentials/youtube_token.pkl

# Path to the Archive folder on this machine (mount ZimaOS via SMB/NFS)
ARCHIVE_PATH=/Volumes/ZimaOS/Archive

# Hour to publish videos (24h format, your local time — Mac must be set to MST)
PUBLISH_HOUR=13

# YouTube channel ID (sanity check — verifies uploads go to the right channel)
YOUTUBE_CHANNEL_ID=UCbPCAaC1iXwTCgVjZQnTDMQ

# YouTube description template (optional — customize this)
# Placeholders: {product}, {amazon_url}
# DESCRIPTION_TEMPLATE=Check out {product} on Amazon!\n\n{amazon_url}\n\n#amazon #amazonfinds
