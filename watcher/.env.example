# Copy this file to .env and fill in your values

# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Path to your Google service account JSON key (inside the container)
GOOGLE_SERVICE_ACCOUNT_FILE=/credentials/service_account.json

# Folder paths (inside the container — map these in docker-compose.yml)
QUEUE_PATH=/queue
ARCHIVE_PATH=/archive

# Anthropic API key — for thumbnail person detection and hook phrase generation
# Get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube settings
YOUTUBE_CHANNEL_ID=UCbPCAaC1iXwTCgVjZQnTDMQ
YOUTUBE_TOKEN_FILE=/credentials/youtube_token.pkl
PUBLISH_HOUR=9
PUBLISH_MINUTE=30

# Amazon affiliate tag (appended to product URLs in YouTube description)
AMAZON_AFFILIATE_TAG=your_affiliate_tag-20
